{
  "compilerOptions": {
    "strict": true,
    "types": ["bun"],
    "jsx": "preserve",
    "jsxImportSource": "solid-js",
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "skipLibCheck": true
  },
  "exclude": [
    "**/build/**",
    "node_modules",
    "submodule/demucs-rs/web",
    "dist",
    "packages/tmp/**"
  ]
}