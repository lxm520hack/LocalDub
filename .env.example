## 翻译 API (OpenAI 兼容)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

## 工作目录 (相对于项目根)
WORKFOLDER=workfolder
MODEL_CACHE_DIR=./data/modelscope

## 设备策略: auto / cuda / cpu
DEVICE=auto

## FFmpeg 路径 (若已在 PATH 中可不设)
FFMPEG_PATH=ffmpeg

# Optional proxy for yt-dlp.
HTTP_PROXY=