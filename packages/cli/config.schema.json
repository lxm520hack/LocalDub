{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "allOf": [
    {
      "type": "object",
      "properties": {
        "command": {
          "type": "string",
          "enum": [
            "startTask",
            "resumeTask",
            "rerunStage",
            "check",
            "taskStatus",
            "createTask",
            "deviceInfo",
            "daemon",
            "daemonStatus",
            "daemonStop",
            "listModels"
          ],
          "description": "1. createTask: 完成后会自动开始任务\n\t\t2. startTask: 直接开始某个已存在的任务 (如之前创建但没有开始的任务)\n\t\t3. resumeTask: 继续任务\n\t\t4. rerunStage: 重新运行某个步骤\n\t\t5. taskStatus: 显示某任务状态\n\t\t6. check: 检测某任务的结果 (如视频是否下载成功, ASR 结果是否合理等)\n\t\t7. deviceInfo: 显示设备信息\n\t\t8. daemon: 启动守护进程\n\t\t9. daemonStatus: 显示守护进程状态\n\t\t10. daemonStop: 停止守护进程\n\t\t11. listModels: 列出 openai 兼容端点的 可用模型\n\t\t"
        },
        "createTask": {
          "type": "object",
          "properties": {
            "youtubeUrl": {
              "type": "string",
              "format": "uri"
            },
            "bilibiliUrl": {
              "type": "string",
              "format": "uri"
            },
            "sourceFile": {
              "description": "本地文件路径或云端文件 url",
              "type": "string"
            },
            "sourceLang": {
              "type": "string"
            },
            "targetLang": {
              "type": "string",
              "enum": [
                "en",
                "zh",
                "vi",
                "ja",
                "ko",
                "fr",
                "de",
                "es",
                "pt",
                "ru",
                "ar",
                "hi",
                "th",
                "id",
                "ms",
                "tl",
                "my",
                "km",
                "lo",
                "mn",
                "ne",
                "ur",
                "bn"
              ]
            }
          },
          "additionalProperties": false
        },
        "startTask": {
          "type": "object",
          "properties": {
            "taskId": {
              "type": "string",
              "description": "任务 ID (timeId(10) 时间序列 + 程序随机数) \\ 视频id (来自视频app) "
            }
          },
          "required": [
            "taskId"
          ],
          "additionalProperties": false
        },
        "resumeTask": {
          "type": "object",
          "properties": {
            "taskId": {
              "type": "string",
              "description": "任务 ID (timeId(10) 时间序列 + 程序随机数) \\ 视频id (来自视频app) "
            },
            "resumeFrom": {
              "type": "string",
              "enum": [
                "download",
                "separate",
                "asr",
                "asr_fix",
                "translate",
                "split_audio",
                "tts",
                "merge_audio",
                "merge_video"
              ]
            }
          },
          "required": [
            "taskId"
          ],
          "additionalProperties": false
        },
        "rerunStage": {
          "type": "object",
          "properties": {
            "taskId": {
              "type": "string",
              "description": "任务 ID (timeId(10) 时间序列 + 程序随机数) \\ 视频id (来自视频app) "
            },
            "stageName": {
              "type": "string",
              "enum": [
                "download",
                "separate",
                "asr",
                "asr_fix",
                "translate",
                "split_audio",
                "tts",
                "merge_audio",
                "merge_video"
              ]
            }
          },
          "required": [
            "taskId",
            "stageName"
          ],
          "additionalProperties": false
        },
        "taskStatus": {
          "type": "object",
          "properties": {
            "taskId": {
              "type": "string",
              "description": "任务 ID (timeId(10) 时间序列 + 程序随机数) \\ 视频id (来自视频app) "
            }
          },
          "required": [
            "taskId"
          ],
          "additionalProperties": false
        },
        "check": {
          "type": "object",
          "properties": {
            "taskId": {
              "type": "string",
              "description": "任务 ID (timeId(10) 时间序列 + 程序随机数) \\ 视频id (来自视频app) "
            },
            "type": {
              "default": "video",
              "type": "string",
              "enum": [
                "video",
                "asr"
              ]
            }
          },
          "required": [
            "taskId",
            "type"
          ],
          "additionalProperties": false
        }
      },
      "required": [
        "command"
      ],
      "additionalProperties": {}
    },
    {
      "type": "object",
      "properties": {
        "pipeline": {
          "description": "任务模式, dub 配音,subtitle 仅字幕",
          "default": "dub",
          "type": "string",
          "enum": [
            "dub",
            "subtitle"
          ]
        },
        "targetStage": {
          "description": "目标步骤, pipeline 跑到此步骤后自动停止, 不指定则跑完所有步骤",
          "type": "string",
          "enum": [
            "download",
            "separate",
            "asr",
            "asr_fix",
            "translate",
            "split_audio",
            "tts",
            "merge_audio",
            "merge_video"
          ]
        },
        "daemonPort": {
          "default": 19109,
          "type": "number"
        },
        "daemonIdleTimeout": {
          "default": 300,
          "type": "number"
        },
        "stages": {
          "type": "object",
          "properties": {
            "download": {
              "type": "object",
              "properties": {},
              "additionalProperties": false
            },
            "separate": {
              "description": "separate: demucs 分离人声与背景声, 提示 tts-vc 的质量 \n\t\tinput: media/video_source.mp4\n\t\toutput: media/target_3_vocals.wav 用于 ASR + TTS reference\n\t\t\t\t\t\tmedia/target_bgm.wav  用于 MergeVideo 背景\n\t",
              "default": {
                "runtime": "pytorch",
                "device": "cuda"
              },
              "oneOf": [
                {
                  "type": "object",
                  "properties": {
                    "runtime": {
                      "type": "string",
                      "const": "pytorch"
                    },
                    "device": {
                      "default": "cuda",
                      "description": "cuda (NVIDIA/ROCm), mps (Apple Silicon)",
                      "type": "string",
                      "enum": [
                        "cuda",
                        "cpu",
                        "mps"
                      ]
                    },
                    "always": {
                      "default": false,
                      "description": "效果(默认关闭): subtitle 模式下也始终分离人声，保留 vocals 以便后续切换到 dub; dub 流程下始终 需要分离人声以 保证 tts-vc 的质量",
                      "type": "boolean"
                    }
                  },
                  "required": [
                    "runtime",
                    "device"
                  ],
                  "additionalProperties": false
                },
                {
                  "type": "object",
                  "properties": {
                    "runtime": {
                      "type": "string",
                      "const": "ort"
                    },
                    "device": {
                      "default": "webgpu",
                      "type": "string",
                      "enum": [
                        "cuda",
                        "rocm",
                        "cpu",
                        "webgpu"
                      ]
                    },
                    "always": {
                      "default": false,
                      "description": "效果(默认关闭): subtitle 模式下也始终分离人声，保留 vocals 以便后续切换到 dub; dub 流程下始终 需要分离人声以 保证 tts-vc 的质量",
                      "type": "boolean"
                    }
                  },
                  "required": [
                    "runtime",
                    "device"
                  ],
                  "additionalProperties": false
                }
              ]
            },
            "asr": {
              "default": {
                "runtime": "pytorch",
                "device": "cuda",
                "useSeparated": false
              },
              "type": "object",
              "properties": {
                "runtime": {
                  "default": "pytorch",
                  "type": "string",
                  "enum": [
                    "faster-whisper",
                    "pytorch"
                  ]
                },
                "device": {
                  "default": "cuda",
                  "type": "string",
                  "enum": [
                    "cuda",
                    "cpu",
                    "mps"
                  ]
                },
                "useSeparated": {
                  "default": false,
                  "description": "使用分离后的人声 (target_3_vocals.wav) 而非原始视频音频",
                  "type": "boolean"
                }
              },
              "required": [
                "runtime",
                "device"
              ],
              "additionalProperties": {}
            },
            "asr_fix": {
              "type": "object",
              "properties": {},
              "additionalProperties": false
            },
            "translate": {
              "type": "object",
              "properties": {
                "apiBase": {
                  "type": "string"
                },
                "model": {
                  "type": "string"
                },
                "targetLang": {
                  "description": "如果不填则 按照这个逻辑: 源语言: zh -> en, 否则 any -> zh",
                  "type": "string",
                  "enum": [
                    "en",
                    "zh",
                    "vi",
                    "ja",
                    "ko",
                    "fr",
                    "de",
                    "es",
                    "pt",
                    "ru",
                    "ar",
                    "hi",
                    "th",
                    "id",
                    "ms",
                    "tl",
                    "my",
                    "km",
                    "lo",
                    "mn",
                    "ne",
                    "ur",
                    "bn"
                  ]
                }
              },
              "additionalProperties": {}
            },
            "split_audio": {
              "type": "object",
              "properties": {},
              "additionalProperties": false
            },
            "tts": {
              "default": {
                "runtime": "pytorch",
                "device": "cuda"
              },
              "oneOf": [
                {
                  "type": "object",
                  "properties": {
                    "runtime": {
                      "type": "string",
                      "const": "pytorch"
                    },
                    "device": {
                      "default": "cuda",
                      "type": "string",
                      "enum": [
                        "cuda",
                        "cpu",
                        "mps"
                      ]
                    }
                  },
                  "required": [
                    "runtime",
                    "device"
                  ],
                  "additionalProperties": false
                },
                {
                  "type": "object",
                  "properties": {
                    "runtime": {
                      "type": "string",
                      "const": "ort",
                      "description": "预留, 暂时没有正确的 onnx 模型文件支持"
                    },
                    "device": {
                      "default": "webgpu",
                      "type": "string",
                      "enum": [
                        "cuda",
                        "rocm",
                        "cpu",
                        "webgpu"
                      ]
                    }
                  },
                  "required": [
                    "runtime",
                    "device"
                  ],
                  "additionalProperties": false
                },
                {
                  "type": "object",
                  "properties": {
                    "runtime": {
                      "type": "string",
                      "const": "ggml"
                    }
                  },
                  "required": [
                    "runtime"
                  ],
                  "additionalProperties": false,
                  "description": "预留 ggml 选项，虽然目前没有实现"
                },
                {
                  "type": "object",
                  "properties": {
                    "runtime": {
                      "type": "string",
                      "const": "cloud"
                    }
                  },
                  "required": [
                    "runtime"
                  ],
                  "additionalProperties": {}
                }
              ]
            },
            "merge_audio": {
              "type": "object",
              "properties": {},
              "additionalProperties": false
            },
            "merge_video": {
              "default": {
                "alignment": "bottom-center",
                "outline": 0,
                "shadow": 1
              },
              "type": "object",
              "properties": {
                "fontSize": {
                  "description": "字幕字号，不填则自动: 竖屏: 12(zh) / 9(其他) ← 横屏: 24(zh) / 18(其他)",
                  "anyOf": [
                    {
                      "type": "number",
                      "minimum": 1,
                      "maximum": 200
                    },
                    {
                      "type": "null"
                    }
                  ]
                },
                "marginV": {
                  "description": "垂直边距(像素)，不填则自动: 竖屏 70 / 横屏 5",
                  "anyOf": [
                    {
                      "type": "number",
                      "minimum": 0
                    },
                    {
                      "type": "null"
                    }
                  ]
                },
                "alignment": {
                  "default": "bottom-center",
                  "type": "string",
                  "enum": [
                    "bottom-left",
                    "bottom-center",
                    "bottom-right",
                    "middle-left",
                    "center",
                    "middle-right",
                    "top-left",
                    "top-center",
                    "top-right"
                  ]
                },
                "outline": {
                  "default": 0,
                  "type": "number",
                  "minimum": 0
                },
                "shadow": {
                  "default": 1,
                  "type": "number",
                  "minimum": 0
                }
              },
              "additionalProperties": false
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": {}
    }
  ]
}