  },
  "dependencies": {
    "@napi-rs/image": "^1.12.0",
    "@repo/config": "workspace:*",
    "onnxruntime-node": "^1.26.0",
    "opencv-wasm": "4.3.0-10",
    "pngjs": "^7.0.0"
  }
}