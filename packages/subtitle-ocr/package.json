{
  "name": "@repo/subtitle-ocr",
  "private": true,
  "type": "module",
  "exports": {
    "./subtitle-node": "./subtitle-node.ts",
    "./subtitle-py": "./subtitle-py.py",
    "./subtitle-cpp": "./subtitle-cpp/ts/ocr.ts"
  },
  "scripts": {
    "build:cpp": "cmake -B subtitle-cpp/build && cmake --build subtitle-cpp/build --parallel",
    "postinstall": "cmake -B subtitle-cpp/build && cmake --build subtitle-cpp/build --parallel 2>/dev/null || echo 'subtitle-cpp: cmake build failed (install cmake + onnxruntime)'"
  },
  "dependencies": {
    "@napi-rs/image": "^1.12.0",
    "onnxruntime-node": "^1.26.0",
    "pngjs": "^7.0.0"
  }
}
