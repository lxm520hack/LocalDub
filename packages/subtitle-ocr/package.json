{
  "name": "@repo/subtitle-ocr",
  "private": true,
  "type": "module",
  "exports": {
    "./subtitle-node": "./subtitle-node.ts",
    "./subtitle-py": "./subtitle-py.py",
    "./subtitle-cpp": "./ort-cpp/ts/ocr.ts",
    "./utils": "./utils.ts"
  },
  "scripts": {
    "test": "bun test",
    "build:cpp": "cmake -B ort-cpp/build && cmake --build ort-cpp/build --parallel",
