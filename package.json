{
  "name": "local-dub-root",
  "private": true,
  "license": "Apache-2.0",
  "scripts": {
    "setup": "bun scripts/setup/setup.ts",
    "run": "bun --cwd packages/cli run-task.ts",
    "test": "bun test",
    "stats": "scc . --exclude-dir node_modules,dist,build,target,venv,.venv,__pycache__,.git,vendor,out,cmake-build-debug,CMakeFiles --exclude-ext lock,json,md,yaml,yml,toml,ini,conf",
    "typecheck": "bun scripts/typecheck.ts"
  },
  "workspaces": [
    "packages/*"
  ],
  "overrides": {
    "onnxruntime-node": "1.26.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@types/bun": "^1.3.14",
    "@typescript/native-preview": "latest",
    "solid-js": "^1.9.13",
    "tailwind": "^4.0.0",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "agnostic-query": "^1.10.7"
  }
}